<?xml version="1.0" encoding="utf-8"?>
<!--
  VS Command Table for Copilot Token Tracker.
  Adds a "Copilot Token Tracker" entry under the View menu.

  GUIDs:
    guidCopilotTokenTrackerPackage    = CopilotTokenTrackerPackage.PackageGuidString
    guidCopilotTokenTrackerCmdSet     = ShowTokenTrackerCommand.CommandSetGuidString
-->
<CommandTable xmlns="http://schemas.microsoft.com/VisualStudio/2005-10-18/CommandTable"
              xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <Extern href="stdidcmd.h"/>
  <Extern href="vsshlids.h"/>

  <Commands package="guidCopilotTokenTrackerPackage">

    <Groups>
      <!-- Place our group inside View > Other Windows -->
      <Group guid="guidCopilotTokenTrackerCmdSet" id="MyMenuGroup" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_MENU_VIEW"/>
      </Group>
    </Groups>

    <Buttons>
      <Button guid="guidCopilotTokenTrackerCmdSet"
              id="ShowTokenTrackerCommandId"
              priority="0x0100"
              type="Button">
        <Parent guid="guidCopilotTokenTrackerCmdSet" id="MyMenuGroup" />
        <Strings>
          <ButtonText>Copilot Token Tracker</ButtonText>
          <CommandName>View.CopilotTokenTracker</CommandName>
          <ToolTipText>Open the Copilot Token Tracker tool window</ToolTipText>
        </Strings>
      </Button>
    </Buttons>

  </Commands>

  <Symbols>
    <GuidSymbol name="guidCopilotTokenTrackerPackage"
                value="{6B8CA5B3-1A9F-4C2E-8F3D-7E2A1B4C9D0F}" />

    <GuidSymbol name="guidCopilotTokenTrackerCmdSet"
                value="{B1C2D3E4-F5A6-B7C8-D9E0-F1A2B3C4D5E6}">
      <IDSymbol name="MyMenuGroup"             value="0x1020" />
      <IDSymbol name="ShowTokenTrackerCommandId" value="0x0100" />
    </GuidSymbol>
  </Symbols>

</CommandTable>
