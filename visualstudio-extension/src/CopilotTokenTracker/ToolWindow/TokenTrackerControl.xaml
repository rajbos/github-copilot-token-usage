<UserControl x:Class="CopilotTokenTracker.ToolWindow.TokenTrackerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <Grid>
        <!-- Fallback message shown while WebView2 is initialising or absent -->
        <TextBlock x:Name="FallbackText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   Foreground="#d4d4d4"
                   FontSize="14"
                   Text="Loading Copilot Token Tracker…" />

        <!-- The embedded Chromium control that hosts the dashboard webview -->
        <wv2:WebView2 x:Name="WebView"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Visibility="Collapsed" />
    </Grid>
</UserControl>
